# Unity recommended line endings
* text=auto

# Unity binary files
*.unity binary
*.prefab binary
*.asset binary
*.mat binary
*.meta text

# Source files
*.cs text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.obj binary
*.fbx binary
*.ttf binary
